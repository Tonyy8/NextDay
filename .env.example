# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: postgresql | sqlite
DB_ENGINE=postgresql

# PostgreSQL
DB_NAME=nextday_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# YOLO Model (optional - defaults to yolov8n.pt)
YOLO_MODEL_PATH=yolov8n.pt

# Full-site mockup mode (no DB / AI required)
MOCK_MODE=True

# OpenWeather (optional — dashboard + recommendation)
OPENWEATHER_API_KEY=
WEATHER_CITY=Ubon Ratchathani
